#!/bin/zsh

set -x

current_branch=`git rev-parse --abbrev-ref HEAD`

if [ "$current_branch" != "main" ]; then
  echo "must be on main branch."
  exit 1
  # TODO: else: stash, checkout main, pull & rebase
fi

git fetch --prune
git rebase origin main --autostash

if [ "$?" = "0" ]; then
  test -e bin/setup

  if [ "$?" = "0" ]; then
    bin/setup
  else
    echo "skipping bin/setup. not found in this project."
  fi

  # TODO: restart server after we finish here
fi

# TODO: if was_on_branch, checkout branch, apply stash
